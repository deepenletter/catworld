OPENAI_API_KEY=sk-proj-xxxx
OPENAI_IMAGE_MODEL=gpt-image-2
PORT=3001

# 전역 일일 예산 상한 (하루 총 성공 생성 수). 이 값에 도달하면 "오늘 마감" 표시.
# Vercel(/api/generate)과 같은 BLOB 저장소를 공유해야 카운터가 합산됩니다.
DAILY_BUDGET_LIMIT=60
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# CORS 허용 도메인(콤마 구분). 설정 시 이 도메인들만 브라우저에서 호출 가능.
# 미설정 시 모든 도메인 허용(경고 로그). 프로덕션에선 반드시 네 사이트 도메인으로 설정.
# 예: ALLOWED_ORIGINS=https://catworld-pi.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=

# 서버가 fetch/렌더할 이미지의 추가 허용 호스트(콤마 구분). 기본으로 Vercel Blob은 허용됨.
ALLOWED_IMAGE_HOSTS=
