# Admin login password
ADMIN_PASSWORD=your-secret-password

# Vercel Blob read/write token
# If you deploy on Vercel, you can also pull this with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Optional: only needed when using AI image editing mode
OPENAI_API_KEY=sk-xxxx
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_OUTPUT_COMPRESSION=82
DAILY_GENERATION_LIMIT=3
DAILY_LIMIT_SECRET=replace-with-a-long-random-secret

# Optional: only needed for direct KakaoTalk share button in the share popup
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# Optional: only needed if you use a separate external image API service
# NEXT_PUBLIC_GENERATE_API_URL=https://your-image-api.onrender.com
